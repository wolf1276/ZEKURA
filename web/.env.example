# Zekura web app configuration. Copy to `.env.local` and fill in.
#
# The active Midnight network (Preview/Preprod) is chosen at runtime from the
# Network Manager (see src/network/networkConfig.ts) — switchable from the UI
# and persisted in the browser, not a build-time env var. Preview is the
# default. What's configured here is per-network data that genuinely can't
# come from the wallet or from the UI: this app's own deployed contract
# address on each network.

# Address of the deployed exchange.compact contract (hex) on Preview.
# Required to submit orders while on Preview. See the repo root README's
# Contract Address table.
NEXT_PUBLIC_EXCHANGE_CONTRACT_ADDRESS_PREVIEW=

# Address of the deployed exchange.compact contract (hex) on Preprod.
# Required to submit orders while on Preprod. Leave blank if not deployed —
# the UI shows a clear "not deployed on this network" message instead of
# failing silently.
NEXT_PUBLIC_EXCHANGE_CONTRACT_ADDRESS_PREPROD=

# Local proof server, used only when the connected wallet does not implement
# getProvingProvider() (e.g. Lace; 1AM Wallet implements it). Same server
# works for both Preview and Preprod (proving happens locally, independent of
# which remote network you're submitting to). Defaults to http://127.0.0.1:6300.
NEXT_PUBLIC_PROOF_SERVER_URL=http://127.0.0.1:6300

# Matcher WebSocket feed (browser -> Matcher, not proxied). Defaults to ws://localhost:4000/ws.
NEXT_PUBLIC_MATCHER_WS_URL=ws://localhost:4000/ws

# Matcher REST base URL, used server-side by the same-origin proxy routes
# (app/api/matcher/**). Defaults to http://localhost:4000.
MATCHER_API_URL=http://localhost:4000
