{
  "name": "zekura",
  "version": "1.0.0",
  "type": "module",
  "description": "Zekura — a privacy-preserving exchange on Midnight. The public ledger stores only orderId, commitment, and state; the confidential order book (asset, amount, side, owner, price) lives off-chain with the Matcher.",
  "author": "",
  "license": "MIT",
  "workspaces": [
    "matcher"
  ],
  "scripts": {
    "compile": "compact compile contracts/exchange.compact contracts/managed/exchange",
    "build": "npx tsc --noEmit || true",
    "setup": "npx tsx src/setup.ts",
    "deploy": "npx tsx src/deploy.ts",
    "cli": "npx tsx src/cli.ts",
    "check-balance": "npx tsx src/check-balance.ts",
    "network": "npx tsx src/network.ts",
    "deploy:retry": "npx tsx scripts/sync-retry.ts npx tsx src/deploy.ts",
    "proof-server:start": "docker compose up -d",
    "proof-server:stop": "docker compose down",
    "clean": "rm -rf contracts/managed .midnight-state.json .midnight-wallet-state",
    "test": "npm run test:exchange",
    "test:exchange": "tsx tests/exchange.test.ts",
    "test:e2e": "tsx scripts/e2e-check.ts"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.5.0",
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.0.4",
    "@midnight-ntwrk/midnight-js-types": "4.0.4",
    "@midnight-ntwrk/midnight-js-utils": "4.0.4",
    "@midnight-ntwrk/wallet-sdk-address-format": "^3.1.2",
    "@midnightntwrk/wallet-sdk-abstractions": "^2.1.0",
    "@midnightntwrk/wallet-sdk-dust-wallet": "^4.2.0",
    "@midnightntwrk/wallet-sdk-facade": "^4.1.0",
    "@midnightntwrk/wallet-sdk-hd": "^3.0.3",
    "@midnightntwrk/wallet-sdk-shielded": "^3.0.2",
    "@midnightntwrk/wallet-sdk-unshielded-wallet": "^3.1.0",
    "clsx": "^2.1.1",
    "motion": "^12.42.2",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "zero-knowledge",
    "privacy"
  ]
}
